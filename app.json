{
  "expo": {
    "name": "Vera Cycle",
    "slug": "vera-cycle-tracker-wcuawy",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-gmt.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app-icon-gmt.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.veracycle.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-gmt.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.veracycle.app",
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/images/newly.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app-icon-gmt.png",
          "color": "#D4607A",
          "sounds": []
        }
      ]
    ],
    "scheme": "veracycle",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {}
    }
  }
}
{
  "expo": {
    "name": "Vera Cycle",
    "slug": "vera-cycle",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.veracycle.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationsUsageDescription": "Vera Cycle uses notifications to remind you when it's time to take your medicine or birth control.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.security.application-groups": [
          "group.com.veracycle.app.onesignal"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.veracycle.app",
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/images/newly.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "production"
        }
      ],
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app-icon-gmt.png",
          "color": "#D4607A",
          "sounds": [],
          "androidPermissions": [
            "POST_NOTIFICATIONS"
          ],
          "androidPermissionDescriptions": {
            "POST_NOTIFICATIONS": "Vera Cycle uses notifications to remind you when it's time to take your medicine or birth control."
          }
        }
      ]
    ],
    "scheme": "veracycle",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "oneSignalAppId": "96532269-7b3a-4209-b660-559075716bfc"
    }
  }
}